              "value": "application/json"
            }
          ]
        },
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={\n  \"model\": \"openai/gpt-oss-120b\",\n  \"messages\": [\n    {\n      \"role\": \"user\",\n      \"content\": \"Write one short B2B outreach line. Name: {{$json.login}}, Followers: {{$json.followers}}, Repos: {{$json.public_repos}}\"\n    }\n  ]\n}",
