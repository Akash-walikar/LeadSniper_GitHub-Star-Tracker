        "jsCode": "const items = $input.all();\nconst stargazers = items[0].json.body;\n\n// Return ALL users (no filtering for now)\nreturn stargazers.map(star => ({\n  json: {\n    username: star.login,\n    avatar_url: star.avatar_url,\n    github_url: star.html_url\n  }\n}));"
