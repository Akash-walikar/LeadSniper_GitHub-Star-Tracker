      "id": "c5ad99a1-45a9-4677-ae3b-7409d19c4da3",
      "name": "AI: Generate Sales Pitch",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        0,
        0
      ],
      "notes": "openai/gpt-oss-120b"
    },
    {
      "parameters": {
        "mode": "runOnceForEachItem",
        "jsCode": "const profile = $('Filter: High-Value Lead?').item.json;\nconst pitchResponse = $input.item.json;\n\nconst pitch = pitchResponse.choices?.[0]?.message?.content || 'Pitch unavailable';\n\nreturn {\n  json: {\n    name: profile.name || profile.login,\n    login: profile.login,\n    company: profile.company || 'N/A',\n    location: profile.location || 'N/A',\n    bio: profile.bio || 'No bio provided',\n    followers: profile.followers,\n    pitch: pitch\n  }\n};"
      },
      "id": "ce285e74-214a-4021-aaab-3427baa64573",
      "name": "Merge Profile + Pitch",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        224,
        0
      ]
    },
    {
      "parameters": {
        "jsCode": "// Log dropped leads for auditing\nconst user = $input.item.json;\nconsole.log(`[FILTERED OUT] @${user.login} — followers: ${user.followers}, repos: ${user.public_repos}`);\nreturn { json: { status: 'filtered', login: user.login, followers: user.followers, public_repos: user.public_repos } };\n"
      },
